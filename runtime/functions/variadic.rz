extends Node

func log_event(name: String, level: int = 0, ...args: Array) -> void:
	prints(name, level, args)

var collector := func(prefix: String, ...args: Array) -> void:
	prints(prefix, args)

func test() -> void:
	log_event("spawn")
	log_event("damage", 2, "orc", 15)
	collector.call("values", 1, 2, 3)

func _ready() -> void:
	test()
