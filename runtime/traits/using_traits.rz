extends Node

trait Interactable:
	signal interacted(by: Node)
	func interact(by: Node) -> void

	func announce(by: Node) -> void:
		interacted.emit(by)

class Doori extends Node:
	uses Interactable

	func interact(by: Node) -> void:
		announce(by)
		print("Door opened by ", by.name)

func test() -> void:
	var door := Doori.new()
	door.interacted.connect(func(n): print(n.name))
	door.interact(self)
	door.free()

func _ready() -> void:
	test()
