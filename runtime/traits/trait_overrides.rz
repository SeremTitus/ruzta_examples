extends Node

trait Highlightable:
	func outline_color() -> Color:
		return Color.YELLOW

class Chest:
	uses Highlightable

	func outline_color() -> Color:
		return Color.ORANGE_RED

func debug_color(target: Chest) -> void:
	print(target.outline_color())

func test() -> void:
	var chest := Chest.new()
	debug_color(chest)

func _ready() -> void:
	test()
